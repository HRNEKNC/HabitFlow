{
  "expo": {
    "name": "Habit Flow",
    "slug": "habitflow",
    "version": "1.0.0",
    "scheme": "habitflow",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splashhrn.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.hrnsoftware.habitflow",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Alışkanlıklarını zamanında hatırlatmak için bildirim gönderiyoruz."
      }
    },
    "android": {
      "android": {
        "package": "com.hrnsoftware.habitflow",
        "versionCode": 1,
        "adaptiveIcon": {
          "foregroundImage": "./assets/images/adaptive-icon.png",
          "backgroundColor": "#0f0f0f"
        },
        "permissions": [
          "NOTIFICATIONS",
          "RECEIVE_BOOT_COMPLETED",
          "VIBRATE",
          "SCHEDULE_EXACT_ALARM",
          "USE_EXACT_ALARM"
        ]
      },
      "package": "com.hrnsoftware.habitflow",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "permissions": ["NOTIFICATIONS", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6366f1",
          "androidMode": "default"
        }
      ],
      "expo-localization",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4311ced4-6e92-4d0b-98fa-416f7ecadba3"
      }
    }
  }
}
